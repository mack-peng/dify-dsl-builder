{
  "name": "dify-dsl-builder",
  "version": "1.0.0",
  "description": "TypeScript OOP library for manipulating Dify DSL YAML files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dify-dsl-cli": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "run": "tsx",
    "typecheck": "tsc --noEmit",
    "web:dev": "webpack serve --config webpack.config.cjs",
    "web:build": "webpack --config webpack.config.cjs --mode production"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4"
  }
}
